# =============================================================================
# Ferdinand mockup — environment variable reference
# Copy to .env.local and fill in values for local development.
# NEVER commit .env.local or any file with real secrets.
# =============================================================================

# Comma-separated list of allowed external API origins (dev only).
# Used by apiBase() to validate the ?api= URL query parameter (#3 SSRF fix).
# Each entry must be a full origin (scheme + host + optional port),
# e.g. "http://localhost:40001,http://dev.example.com".
# Leave empty in production to enforce same-origin only.
PUBLIC_API_ALLOWED_BASES=
