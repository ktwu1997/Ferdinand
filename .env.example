# Ferdinand local env template — copy to `.env` and fill in your secrets.
#   cp .env.example .env
#   $EDITOR .env
#
# Then source it before running tests / the dev server:
#   set -a; source .env; set +a
#
# `.env` is gitignored. NEVER commit a filled-in copy.
#
# This file documents two environment surfaces:
#   1. Dev / E2E test runs   (FERDINAND_TEST_*, optional bind tuning)
#   2. Production docker-compose.yml deploy (DOMAIN, BASIC_AUTH_*, etc.)
#
# Sensitivity tags:
#   PUBLIC — appears in DNS, TLS certs, or HTTP responses; not a secret.
#   SECRET — must be kept private; rotate if exposed.

# ---- E2E test credentials -------------------------------------------------
# Used by mockup/tests/e2e/{a1_browse_validation,a2_auth_endpoints}.mjs to
# log in as an existing user before exercising protected /api/* routes.
FERDINAND_TEST_USER=ktwu
FERDINAND_TEST_PASSWORD=

# ---- Seed user (first-run bootstrap) --------------------------------------
# Only effective when the named user does NOT already exist in auth.db.
# Set both to auto-create on `cargo run -p anki_server`. Idempotent —
# leaving these set after the user exists is a no-op.
# Sensitivity: SECRET (FERDINAND_SEED_PASSWORD is the plaintext login pwd).
FERDINAND_SEED_USER=
FERDINAND_SEED_PASSWORD=

# ---- Server bind / port (optional, dev) -----------------------------------
# Defaults: ANKI_BIND=127.0.0.1, ANKI_SERVER_PORT=40001
# Set ANKI_BIND=0.0.0.0 to expose to LAN (then SESSION_KEY becomes mandatory).
# ANKI_BIND=127.0.0.1
# ANKI_SERVER_PORT=40001

# ===========================================================================
#  Production docker-compose.yml variables
#  Every ${VAR:?...} reference in docker-compose.yml is covered below.
#  For an interactive populator, run: bash deploy/scripts/init-env.sh
# ===========================================================================

# ---------------------------------------------------------------------------
# DOMAIN — public hostname for the Caddy reverse proxy.
# Sensitivity: PUBLIC (appears in DNS / TLS).
# Required by docker-compose.yml.
# Set this to the FQDN whose A record points at this VPS. Caddy uses it to
# request a Let's Encrypt cert via HTTP-01 on port 80.
# Example: anki.example.com
DOMAIN=anki.example.com

# ---------------------------------------------------------------------------
# BASIC_AUTH_USER — username for Caddy's HTTP basic_auth gate.
# Sensitivity: PUBLIC (sent in clear over TLS, but visible to anyone who
# inspects browser network traffic). Pick something unguessable but not
# secret-grade.
# Required by docker-compose.yml.
# Example: friend
BASIC_AUTH_USER=change-me-username

# ---------------------------------------------------------------------------
# BASIC_AUTH_HASH — bcrypt hash of the basic_auth password (NOT the plaintext).
# Sensitivity: SECRET (anyone with this hash can mount an offline crack).
# Required by docker-compose.yml.
# Generate (do NOT paste the plaintext into this file):
#     docker run --rm caddy:2 caddy hash-password --plaintext '<your-password>'
# The hash starts with `$2a$14$...` — single-quote it because `$` triggers
# shell expansion otherwise.
BASIC_AUTH_HASH='<run: docker run --rm caddy:2 caddy hash-password --plaintext PASSWORD>'

# ---------------------------------------------------------------------------
# FERDINAND_SESSION_KEY — HMAC key for cookie-based session signing.
# Sensitivity: SECRET (rotation invalidates every active session).
# Required by docker-compose.yml when ANKI_BIND is non-loopback (the default
# in compose).
# Generate:
#     openssl rand -base64 64 | tr -d '\n'
# Produces an 88-char string on a single line.
FERDINAND_SESSION_KEY=<run: openssl rand -base64 64>

# ---------------------------------------------------------------------------
# ACME_EMAIL — Let's Encrypt contact email.
# Sensitivity: PUBLIC (used by LE for cert-renewal-failure notifications).
# Optional. Strongly recommended in production.
# Example: you@example.com
ACME_EMAIL=

# ---------------------------------------------------------------------------
# ANKI_ADMIN_USERNAME — only this username can access /api/admin/*.
# Sensitivity: PUBLIC (no secret value, but knowing it narrows the attack
# surface). Leave EMPTY to disable admin endpoints entirely (recommended
# unless you actively need them).
# Optional.
ANKI_ADMIN_USERNAME=

# ---------------------------------------------------------------------------
# ANKI_IMPORT_MAX_BYTES — cap on .apkg upload size, in bytes.
# Sensitivity: PUBLIC.
# Optional. Defaults to a code-side value when blank.
# 104857600 = 100 MiB.
ANKI_IMPORT_MAX_BYTES=104857600
