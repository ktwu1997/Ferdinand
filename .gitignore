# Anki runtime collection — local SQLite DB, never commit.
# data/collection.anki2 (+ -wal/-shm) is now a symlink into data/users/<name>/
# for backward compat with scripts; data/users/ is the canonical Phase A1 layout.
data/collection.anki2
data/collection.anki2-wal
data/collection.anki2-shm
data/collection.anki2.*-bak
data/collection.media
data/collection.media/
data/users/

# Per-deck pipeline runtime state (committed: wordlist.jsonl + cards.jsonl)
data/*/done.txt
data/*/ingested.txt
data/*/failed.jsonl
data/*/cards.invalid.jsonl
data/*/cards.v1.jsonl
# TOEIC subtype variants (cloze / reading have their own prefixed trackers)
data/toeic/cloze_done.txt
data/toeic/cloze_ingested.txt
data/toeic/cloze_failed.jsonl
# Image backfill runtime state (per-deck Image field)
data/*/image_done.txt
data/*/image_skip.txt
data/*/image_fail.jsonl
data/*/image_verified.jsonl
data/*/image_map.json

.claude/
